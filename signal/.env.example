# Copy to .env and fill in values for local development.

DATABASE_URL=postgresql://nexus:<password>@localhost:5432/backtest
KAFKA_BROKERS=localhost:32092
POLYGON_API_KEY=<your-polygon-api-key>

# Optional: path to the trained ONNX insider-score model.
# If unset or the file does not exist, signal runs without scoring.
# Train the model with: python ml/train_insider_score.py
INSIDER_MODEL_PATH=./ml/insider_score.onnx

# Required by the ort crate (ONNX Runtime Rust bindings).
# macOS:  brew install onnxruntime
# Linux:  apt-get install libonnxruntime-dev  or  download from github.com/microsoft/onnxruntime/releases
# Point this to the directory containing libonnxruntime.dylib / libonnxruntime.so.
ORT_DYLIB_PATH=/opt/homebrew/lib/libonnxruntime.dylib
